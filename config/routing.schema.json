{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CueLine routing configuration",
  "type": "object",
  "required": ["version", "lanes"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "lanes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "candidates"],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "candidates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "argv"],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "argv": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "task_input": {
                  "enum": ["argv", "stdin"]
                },
                "enabled": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
